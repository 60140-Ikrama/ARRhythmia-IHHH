{
    "data_quality": {
        "min_fps": 15,
        "max_missing_frames": 2,
        "min_snr": 5.0,
        "min_laplacian_var": 10.0
    },
    "segmentation": {
        "unet_model_path": "models/unet_weights.pth",
        "spacing_cm": 0.15,
        "min_area_pixels": 100,
        "max_area_pixels": 8000
    },
    "motion": {
        "optical_flow_pyr_scale": 0.5,
        "optical_flow_levels": 3,
        "optical_flow_winsize": 15,
        "optical_flow_iterations": 3,
        "optical_flow_poly_n": 5,
        "optical_flow_poly_sigma": 1.2
    },
    "mrvm": {
        "rhythm_regularity_threshold": 0.08,
        "afib_irregularity_threshold": 0.15
    },
    "classification": {
        "model_path": "models/xgboost_arrhythmia.json",
        "scaler_path": "models/scaler_params.json"
    },
    "uncertainty": {
        "confidence_threshold": 0.70,
        "ood_threshold": 3.0
    }
}
